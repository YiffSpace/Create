{
  "description": "Bun as a library",
  "args": [
    {
      "name": "bun-version",
      "required": false,
      "default": "1.3.0",
      "type": "string"
    },
    {
      "name": "tests",
      "required": false,
      "default": true,
      "type": "boolean"
    },
    {
      "name": "publish",
      "required": false,
      "default": true,
      "type": "boolean"
    },
    {
      "name": "description",
      "required": true,
      "default": "A bun library",
      "type": "string"
    },
    {
      "name": "repository-url",
      "required": true,
      "default": "https://github.com/YiffSpace/Create",
      "type": "string"
    },
    {
      "name": "git",
      "required": true,
      "default": true,
      "type": "boolean"
    },
    {
      "name": "git-branch",
      "required": true,
      "default": "master",
      "type": "string"
    }
  ],
  "scripts": ["install.sh"]
}
