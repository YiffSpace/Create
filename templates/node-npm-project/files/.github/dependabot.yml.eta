version: 2
updates:
  - package-ecosystem: "bun"
    directory: "/"
    schedule:
      interval: "monthly"
    assignees:
      - "DonovanDMC"
    commit-message:
      include: "scope"
      prefix: ""
    target-branch: "<%= it.gitBranch %>"
    versioning-strategy: "increase"
    labels:
      - "dependencies"
